{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "Agent": {
    "Provider": "OpenRouter",
    "OpenAi": {
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "gpt-4",
      "Temperature": 0.7,
      "MaxTokens": 2000
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3",
      "Temperature": 0.7,
      "MaxTokens": 2000
    },
    "OpenRouter": {
      "BaseUrl": "https://openrouter.ai/api/v1",
      "Model": "google/gemma-3n-e2b-it:free",
      "Temperature": 0.7,
      "MaxTokens": 2000
    }
  },

  "TemplateStorage": {
    "TemplateFolder": "Templates",
    "DatabasePath": "Data/template.db"
  },

  "PresentationStorage": {
    "DatabasePath": "Data/presentation.db"
  },

  "Storage": {
    "StoragePath": "Documents",
    "DatabasePath": "Data/storage.db"
  }
}
